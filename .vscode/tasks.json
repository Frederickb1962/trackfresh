{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TrackFresh: Dev Server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "trackfresh",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Ready in|Local:\\s+http)"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "trackfresh"
      }
    },
    {
      "label": "TrackFresh: Open Preview in Cursor",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/open-cursor-preview.sh",
      "presentation": { "reveal": "silent", "panel": "shared", "close": true },
      "problemMatcher": []
    },
    {
      "label": "TrackFresh: Restore Editing Layout",
      "dependsOn": ["TrackFresh: Dev Server", "TrackFresh: Wait and Open Preview"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "runOptions": { "runOn": "folderOpen" }
    },
    {
      "label": "TrackFresh: Wait and Open Preview",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/wait-for-dev-and-preview.sh",
      "presentation": { "reveal": "silent", "panel": "shared", "close": true },
      "problemMatcher": []
    },
    {
      "label": "TrackFresh: Clean Dev Server",
      "type": "shell",
      "command": "npm run dev:clean",
      "isBackground": true,
      "problemMatcher": {
        "owner": "trackfresh",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Ready in|Local:\\s+http)"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "trackfresh" }
    }
  ]
}
